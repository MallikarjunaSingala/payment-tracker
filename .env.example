# ---------------------------------------------------------------------------
# Google Sheets API credentials (Service Account)
# See README.md "Google Sheets API Setup Guide" for how to generate these.
# ---------------------------------------------------------------------------

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your-google-sheet-id-here

# The "client_email" field from the service account JSON key file
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# The "private_key" field from the service account JSON key file.
# Keep the quotes and \n sequences exactly as they appear in the JSON file.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Optional: how long (ms) sheet data is cached in memory per server instance.
# Lower = fresher data but more Google Sheets API calls. Default: 30000 (30s)
SHEETS_CACHE_TTL_MS=30000

# ---------------------------------------------------------------------------
# Simple login gate (4 shared-password users)
# ---------------------------------------------------------------------------

# Comma-separated list of the only usernames allowed to sign in.
AUTH_USERS=Mallikarjuna,Raju,Naik,Shakir

# Shared password for all of the above users. Set this to your own real
# password directly in Vercel's Environment Variables settings - never
# commit a real password here, since this file (and its git history) is
# public.
AUTH_PASSWORD=choose-your-own-password

# Long random string used to sign the session cookie. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-string

# ---------------------------------------------------------------------------
# Contractor self-service portal (magic links)
# ---------------------------------------------------------------------------

# Long random string used to sign per-contractor portal links. Generate one
# with: openssl rand -hex 32
# Required for the "Copy Portal Link" button and /portal/[token] pages to
# work. If unset, the portal is disabled (fails closed).
CONTRACTOR_PORTAL_SECRET=change-this-to-a-long-random-string
